{
  "name": "nong-xin-zhi-jing",
  "private": true,
  "version": "1.0.0",
  "description": "农芯智境 - 智慧农业管理系统",
  "author": "Admin",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "dev": "tsx server.ts",
    "build:frontend": "vite build",
    "build:server": "esbuild server.ts --bundle --platform=node --format=esm --outfile=dist/server.js --minify --external:vite --external:electron",
    "build": "npm run build:frontend && npm run build:server",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "start": "node server.ts",
    "start:pc": "electron .",
    "build:web": "npm run build",
    "build:edgeone": "npm run build:frontend && esbuild server.ts --bundle --platform=node --format=cjs --outfile=dist/server.cjs --minify --external:vite --external:electron",
    "start:web": "node dist/server.js",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win"
  },
  "build": {
    "appId": "com.nxzj.app",
    "productName": "农芯智境",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.cjs",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    }
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "electron": "^30.5.1",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "i18next": "^26.0.4",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^17.0.2",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "rss-parser": "^3.13.0",
    "tailwind-merge": "^3.5.0",
    "xlsx": "^0.18.5"
  }
}
